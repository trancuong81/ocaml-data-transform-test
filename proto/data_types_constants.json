{
  "String": {
    "typeId": "String"
  },
  "Ssn": {
    "typeId": "Ssn",
    "regex": "^(0\\d[1-9]|0[1-9]\\d|6\\d[0-57-9]|6[0-57-9]\\d|[1-57-8]\\d{2})-?(\\d[1-9]|[1-9]\\d)-?(\\d{3}[1-9]|\\d{2}[1-9]\\d|\\d[1-9]\\d{2}|[1-9]\\d{3})$",
    "formatPatterns": ["000-00-0000"]
  },
  "Ein": {
    "typeId": "Ein",
    "regex": "^(0[1-6]|1[0-6]|2[0-7]|[35]\\d|[468][0-8]|7[1-7]|9[0-58-9])-?\\d{7}$",
    "formatPatterns": ["00-0000000"]
  },
  "Aba": {
    "typeId": "Aba",
    "regex": "^(0[0-9]|1[0-2]|2[1-9]|3[0-2]|6[1-9]|7[0-2]|80)\\d{7}$",
    "formatPatterns": ["000000000"]
  },
  "Itin": {
    "typeId": "Itin",
    "regex": "^9\\d{2}-?(5\\d|6[0-5]|9[0-2]|9[4-9])-?\\d{4}$",
    "formatPatterns": ["000-00-0000"]
  },
  "Swift": {
    "typeId": "Swift",
    "regex": "^([a-zA-Z]){4}([a-zA-Z]){2}([0-9a-zA-Z]){2}([0-9a-zA-Z]{3})?$",
    "formatPatterns": ["aaaaaa**", "aaaaaa*****"]
  },
  "Iban": {
    "typeId": "Iban",
    "regex": "^[a-zA-Z]{2}\\s?[0-9]{2}.*"
  },
  "Giin": {
    "typeId": "Giin",
    "regex": "^[A-NP-Z0-9]{6}\\.[A-NP-Z0-9]{5}\\.[A-Z]{2}\\.\\d{3}$",
    "formatPatterns": ["000000.00000.XX.000"]
  },
  "UsZip": {
    "typeId": "UsZip",
    "regex": "^\\d{5}(-\\d{4})?$",
    "formatPatterns": ["00000", "00000-0000"]
  },
  "Email": {
    "typeId": "Email",
    "regex": "\\b([a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+)@([a-zA-Z0-9-]+(?:\\.[a-zA-Z0-9-]+)+)\\b"
  },
  "PhoneFaxString": {
    "typeId": "PhoneFaxString",
    "regex": "^\\+?[\\(\\)\\d\\s-+]+$"
  },
  "DateTimeString": {
    "typeId": "DateTimeString"
  },
  "TimeZoneOffset": {
    "typeId": "TimeZoneOffset"
  },
  "Boolean": {
    "typeId": "Boolean"
  },
  "Integer": {
    "typeId": "Integer"
  },
  "Float": {
    "typeId": "Float"
  },
  "Percentage": {
    "typeId": "Percentage",
    "min": 0,
    "max": 100
  },
  "Year": {
    "typeId": "Year"
  },
  "MoneyString": {
    "typeId": "MoneyString"
  },
  "IsoCurrencyCode": {
